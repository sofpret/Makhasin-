---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Contact — Ahmad Makhasin As Shufi"
  description="Hubungi Ahmad Makhasin As Shufi untuk kolaborasi, diskusi, atau apapun."
>
  <Navbar active="contact" />

  <main id="main">
    <section class="section-wrap">
      <div class="contact-layout">
        <div class="contact-left reveal">
          <div class="overline">Kontak</div>
          <h1 class="contact-title">
            Ada yang ingin<br />
            <span style="color:#dc1414">dibicarakan?</span>
          </h1>
          <p class="contact-desc">
            Gue terbuka untuk diskusi seputar networking, kolaborasi proyek,
            atau sekadar ngobrol soal teknologi. Kirim pesan — gue baca semua.
          </p>

          <div class="contact-links">
            <a href="mailto:hello@ahmadmakhasin.dev" class="contact-item">
              <div class="contact-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </div>
              <div>
                <div class="contact-label">Email</div>
                <div class="contact-val">hello@ahmadmakhasin.dev</div>
              </div>
            </a>

            <a href="https://linkedin.com/in/yourusername" target="_blank" rel="noopener noreferrer" class="contact-item">
              <div class="contact-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
              </div>
              <div>
                <div class="contact-label">LinkedIn</div>
                <div class="contact-val">Ahmad Makhasin As Shufi</div>
              </div>
            </a>

            <a href="https://github.com/yourusername" target="_blank" rel="noopener noreferrer" class="contact-item">
              <div class="contact-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
              </div>
              <div>
                <div class="contact-label">GitHub</div>
                <div class="contact-val">github.com/yourusername</div>
              </div>
            </a>
          </div>
        </div>

        <!-- Form kanan -->
        <div class="contact-right reveal d2">
          <form class="contact-form" id="contact-form" novalidate>
            <div class="form-group">
              <label for="name" class="form-label">Nama</label>
              <input type="text" id="name" name="name" class="form-input" placeholder="Nama kamu" required autocomplete="name" />
            </div>

            <div class="form-group">
              <label for="email" class="form-label">Email</label>
              <input type="email" id="email" name="email" class="form-input" placeholder="email@kamu.com" required autocomplete="email" />
            </div>

            <div class="form-group">
              <label for="subject" class="form-label">Topik</label>
              <input type="text" id="subject" name="subject" class="form-input" placeholder="Networking, kolaborasi, dll." />
            </div>

            <div class="form-group">
              <label for="message" class="form-label">Pesan</label>
              <textarea id="message" name="message" class="form-input form-textarea" placeholder="Tulis pesannya di sini..." required rows="5"></textarea>
            </div>

            <button type="submit" class="btn-main form-submit">
              Kirim Pesan
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </button>
          </form>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const btn = form.querySelector(".form-submit") as HTMLButtonElement;
    if (btn) {
      btn.textContent = "Terkirim";
      btn.style.background = "#10b981";
      btn.disabled = true;
      setTimeout(() => {
        btn.textContent = "Kirim Pesan";
        btn.style.background = "";
        btn.disabled = false;
        form.reset();
      }, 3000);
    }
  });
</script>

<style>
  #main { position: relative; z-index: 10; }

  .contact-layout {
    display: flex;
    flex-direction: column;
    gap: 56px;
  }

  @media (min-width: 900px) {
    .contact-layout {
      flex-direction: row;
      align-items: flex-start;
      gap: 80px;
    }
    .contact-left { flex: 0 0 380px; }
    .contact-right { flex: 1; }
  }

  .contact-title {
    font-size: clamp(36px, 6vw, 56px);
    margin-bottom: 20px;
  }

  .contact-desc {
    font-size: 14.5px;
    font-weight: 300;
    line-height: 1.8;
    color: rgba(240,240,240,0.38);
    margin-bottom: 40px;
    max-width: 340px;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    text-decoration: none;
    transition: padding-left 0.25s;
  }
  .contact-item:hover { padding-left: 6px; }
  .contact-item:last-child { border-bottom: none; }

  .contact-icon {
    width: 40px;
    height: 40px;
    border: 1px solid rgba(255,255,255,0.07);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(240,240,240,0.4);
    flex-shrink: 0;
    transition: color 0.2s, border-color 0.2s;
  }
  .contact-item:hover .contact-icon {
    color: #dc1414;
    border-color: rgba(220,20,20,0.35);
  }

  .contact-label {
    font-family: "Inter", sans-serif;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(240,240,240,0.25);
    margin-bottom: 3px;
  }

  .contact-val {
    font-family: "Inter", sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: rgba(240,240,240,0.65);
  }

  /* FORM */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form-label {
    font-family: "Inter", sans-serif;
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(240,240,240,0.35);
  }

  .form-input {
    font-family: "Inter", sans-serif;
    font-size: 14px;
    font-weight: 300;
    color: rgba(240,240,240,0.8);
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    padding: 12px 16px;
    outline: none;
    width: 100%;
    transition: border-color 0.2s;
    appearance: none;
    -webkit-appearance: none;
    border-radius: 0;
  }

  .form-input::placeholder {
    color: rgba(240,240,240,0.18);
  }

  .form-input:focus {
    border-color: rgba(220,20,20,0.45);
  }

  .form-textarea {
    resize: vertical;
    min-height: 140px;
  }

  .form-submit {
    align-self: flex-start;
    margin-top: 8px;
  }
</style>
