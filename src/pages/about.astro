---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="About — Ahmad Makhasin As Shufi">
  <Navbar active="about" />

  <main class="about-main">
    <!-- Page header dengan background gelap -->
    <div class="page-header">
      <div class="page-header-mesh" aria-hidden="true"></div>
      <div class="page-header-inner">
        <div class="overline" style="color:#a78bfa">About</div>
        <h1 class="page-h1">
          Dua dunia,<br />
          <em>satu kepala.</em>
        </h1>
      </div>
    </div>

    <div class="section-divider" aria-hidden="true"></div>

    <!-- Bio -->
    <section class="about-section" style="background:#f0ecff">
      <div class="section-wrap">
        <div class="about-bio-grid">
          <div class="reveal">
            <div class="section-tag">Tentang Gue</div>
            <h2 class="about-section-title">
              Bukan dua hal<br /><em>yang bertabrakan.</em>
            </h2>
          </div>
          <div class="about-bio-text reveal d2">
            <p class="about-lead">
              Hai Saya Ahmad Makhasin As Shufi. Secara formal, mahasiswa
              Manajemen Pendidikan Sih. Tapi kalau ditanya passion, jawabannya
              selalu sama yaitu jaringan, sistem, dan hal-hal yang bergerak
              di bawah permukaan.
            </p>
            <p>
              Saya percaya latar belakang yang berbeda justru menghasilkan
              cara berpikir yang lebih kaya. Memahami bagaimana Hidup ini
              bekerja membantu gue merancang infrastruktur yang tidak hanya
              teknis tapi juga masuk akal untuk digunakan orang sungguhan.
            </p>
            <p style="margin-top:16px">
              Sampai sekarang masih belajar dan itu bukan hal yang perlu
              dimaafkan. Network engineering adalah bidang yang tidak ada
              habisnya. Setiap kali ada yang dikuasai, ada tiga hal baru
              yang menunggu.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Interests -->
    <section style="background:linear-gradient(180deg,#f0ecff 0%,#e8f4ff 100%);padding:80px 0">
      <div class="section-wrap">
        <div class="section-tag reveal">Bidang Minat</div>
        <h2 class="about-section-title reveal d1" style="margin-bottom:40px">
          Yang membuat<br /><em>gue betah.</em>
        </h2>

        <div class="interests-grid">
          {[
            { num:"01", title:"Network Engineering",   desc:"Routing, switching, protokol. Arsitektur yang menghubungkan segalanya.", c:"violet" },
            { num:"02", title:"Linux & Sysadmin",      desc:"Server, shell, dan sistem yang berjalan tanpa gangguan.",              c:"cyan"   },
            { num:"03", title:"Network Security",      desc:"Firewall, IDS, dan berpikir seperti orang yang mau masuk tanpa izin.", c:"violet" },
            { num:"04", title:"Infrastructure Design", desc:"Topologi yang efisien, skalabel, dan tahan banting.",                  c:"cyan"   },
          ].map((item, i) => (
            <div class={`interest-card card reveal d${i+1}`}>
              <div class={`int-num int-num--${item.c}`}>{item.num}</div>
              <h3 class="int-title">{item.title}</h3>
              <p class="int-desc">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .about-main { padding-top: 0; }

  .page-header {
    background: linear-gradient(160deg, #2d1b69, #1a1035, #0f2744);
    padding: 140px 24px 72px;
    position: relative;
    overflow: hidden;
  }

  .page-header-mesh {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 60% at 80% 30%, rgba(139,92,246,0.28) 0%, transparent 60%),
      radial-gradient(ellipse 50% 70% at 10% 80%, rgba(34,211,238,0.14) 0%, transparent 55%);
    pointer-events: none;
  }

  .page-header-inner {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  @media (min-width: 768px) {
    .page-header       { padding: 160px 48px 80px; }
    .page-header-inner { padding: 0 48px; }
  }

  .page-h1 {
    font-size: clamp(40px, 8vw, 72px);
    color: #f0eeff;
  }
  .page-h1 em { font-style: normal; color: #22d3ee; }

  /* Bio */
  .about-bio-grid {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  @media (min-width: 768px) {
    .about-bio-grid {
      flex-direction: row;
      gap: 80px;
      align-items: flex-start;
    }
    .about-bio-grid > *:first-child { flex: 0 0 300px; }
    .about-bio-grid > *:last-child  { flex: 1; }
  }

  .about-section-title {
    font-size: clamp(28px, 5vw, 44px);
    color: #1a1035;
    margin-top: 8px;
  }
  .about-section-title em { font-style: normal; color: #7c3aed; }

  .about-lead {
    font-size: 16px;
    font-weight: 500;
    line-height: 1.8;
    color: #4a3f72;
    margin-bottom: 18px;
  }

  /* Interests */
  .interests-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  @media (min-width: 560px) {
    .interests-grid { grid-template-columns: 1fr 1fr; }
  }

  .interest-card {
    padding: 28px 24px;
  }

  .int-num {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  .int-num--violet { color: #7c3aed; }
  .int-num--cyan   { color: #0891b2; }

  .int-title {
    font-family: "Syne", sans-serif;
    font-size: 17px;
    font-weight: 700;
    color: #1a1035;
    margin-bottom: 10px;
    letter-spacing: -0.02em;
    line-height: 1.25;
  }

  .int-desc {
    font-size: 13.5px;
    line-height: 1.75;
    color: #6b6080;
  }
</style>
