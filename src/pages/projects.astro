---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const projects = [
  {
    num: "001",
    title: "Lab Jaringan Enterprise",
    desc: "Simulasi jaringan enterprise dengan multi-VLAN, inter-VLAN routing, OSPF, dan NAT menggunakan GNS3. Topologi 3-tier dengan core, distribution, dan access layer.",
    tags: ["GNS3", "Cisco IOS", "OSPF", "VLAN", "NAT"],
    status: "Selesai",
  },
  {
    num: "002",
    title: "Firewall & DMZ Setup",
    desc: "Konfigurasi pfSense sebagai firewall utama dengan DMZ zone untuk web server. Implementasi rules berbasis zone dan IDS dasar menggunakan Snort.",
    tags: ["pfSense", "Snort", "DMZ", "Firewall Rules"],
    status: "Selesai",
  },
  {
    num: "003",
    title: "Monitoring Jaringan",
    desc: "Setup monitoring infrastruktur menggunakan Zabbix. Konfigurasi SNMP trap, alert email, dan dashboard visualisasi traffic real-time.",
    tags: ["Zabbix", "SNMP", "Linux", "Monitoring"],
    status: "On-going",
  },
  {
    num: "004",
    title: "MikroTik Hotspot System",
    desc: "Implementasi sistem hotspot berbasis MikroTik RouterOS untuk lingkungan kampus kecil. User management, bandwidth throttling, dan daily traffic report.",
    tags: ["MikroTik", "RouterOS", "Hotspot", "Bandwidth"],
    status: "Selesai",
  },
  {
    num: "005",
    title: "Bash Automation Scripts",
    desc: "Kumpulan script bash untuk otomasi task sysadmin — backup otomatis, monitoring disk usage, log cleaner, dan cek koneksi periodik.",
    tags: ["Bash", "Linux", "Cron", "Automation"],
    status: "On-going",
  },
  {
    num: "006",
    title: "IPv6 Migration Lab",
    desc: "Lab eksplorasi migrasi IPv4 ke IPv6 dengan dual-stack dan tunnel 6in4. Masih eksperimen — banyak yang belum dipahami, tapi itu poinnya.",
    tags: ["IPv6", "Dual-stack", "Tunnel", "Routing"],
    status: "Explorasi",
  },
];
---

<Layout
  title="Projects — Ahmad Makhasin As Shufi"
  description="Lab, proyek, dan eksperimen jaringan Ahmad Makhasin As Shufi."
>
  <Navbar active="projects" />

  <main id="main">
    <section class="section-wrap">
      <div class="overline reveal">Proyek & Lab</div>
      <h1 class="page-title reveal d1">
        Yang sudah<br />
        <span style="color:#dc1414">dikerjakan.</span>
      </h1>
      <p class="page-sub reveal d2">
        Bukan semuanya sempurna. Beberapa masih jalan, beberapa masih
        eksperimen. Tapi semuanya nyata dan semuanya dipelajari.
      </p>

      <div class="projects-grid">
        {projects.map((p, i) => (
          <article class={`card project-card reveal d${(i % 3) + 1}`}>
            <div class="project-header">
              <span class="project-num">{p.num}</span>
              <span class={`project-status ${p.status === "Selesai" ? "status-done" : p.status === "On-going" ? "status-ongoing" : "status-explore"}`}>
                {p.status}
              </span>
            </div>
            <h3 class="project-title">{p.title}</h3>
            <p class="project-desc">{p.desc}</p>
            <div class="project-tags">
              {p.tags.map((t) => (
                <span class="tag">{t}</span>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  #main { position: relative; z-index: 10; }

  .page-title {
    font-size: clamp(40px, 8vw, 72px);
    margin-bottom: 16px;
  }

  .page-sub {
    font-size: 14.5px;
    font-weight: 300;
    line-height: 1.8;
    color: rgba(240,240,240,0.38);
    max-width: 480px;
    margin-bottom: 56px;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.07);
  }

  @media (min-width: 640px) {
    .projects-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (min-width: 1024px) {
    .projects-grid { grid-template-columns: 1fr 1fr 1fr; }
  }

  .project-card {
    padding: 28px 24px;
    background: #080808;
    border: none;
    border-radius: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: background 0.25s;
    cursor: default;
  }
  .project-card:hover { background: #0e0e0e; }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .project-num {
    font-family: "Syne", sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: rgba(240,240,240,0.2);
  }

  .project-status {
    font-size: 9.5px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 3px 9px;
    border: 1px solid;
  }

  .status-done    { color: #10b981; border-color: rgba(16,185,129,0.3); background: rgba(16,185,129,0.07); }
  .status-ongoing { color: #f59e0b; border-color: rgba(245,158,11,0.3); background: rgba(245,158,11,0.07); }
  .status-explore { color: rgba(240,240,240,0.4); border-color: rgba(255,255,255,0.1); }

  .project-title {
    font-family: "Syne", sans-serif;
    font-size: 17px;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.25;
    color: #f0f0f0;
  }

  .project-desc {
    font-size: 13px;
    font-weight: 300;
    line-height: 1.75;
    color: rgba(240,240,240,0.35);
    flex: 1;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 4px;
  }
</style>
