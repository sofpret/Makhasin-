---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const projects = [
  { num:"001", title:"Lab Jaringan Enterprise",   status:"Selesai",    tags:["GNS3","Cisco IOS","OSPF","VLAN","NAT"],       desc:"Simulasi jaringan enterprise dengan multi-VLAN, inter-VLAN routing, OSPF, dan NAT. Topologi 3-tier dengan core, distribution, dan access layer." },
  { num:"002", title:"Firewall & DMZ Setup",       status:"Selesai",    tags:["pfSense","Snort","DMZ","Firewall Rules"],      desc:"Konfigurasi pfSense sebagai firewall utama dengan DMZ zone untuk web server dan IDS dasar menggunakan Snort." },
  { num:"003", title:"Monitoring Jaringan",        status:"On-going",   tags:["Zabbix","SNMP","Linux","Monitoring"],         desc:"Setup monitoring infrastruktur menggunakan Zabbix dengan SNMP trap, alert email, dan dashboard visualisasi traffic real-time." },
  { num:"004", title:"MikroTik Hotspot System",   status:"Selesai",    tags:["MikroTik","RouterOS","Hotspot","Bandwidth"],  desc:"Implementasi sistem hotspot berbasis MikroTik RouterOS untuk lingkungan kampus kecil dengan bandwidth throttling." },
  { num:"005", title:"Bash Automation Scripts",   status:"On-going",   tags:["Bash","Linux","Cron","Automation"],           desc:"Kumpulan script bash untuk otomasi task sysadmin — backup otomatis, monitoring disk, log cleaner, dan cek koneksi periodik." },
  { num:"006", title:"IPv6 Migration Lab",        status:"Explorasi",  tags:["IPv6","Dual-stack","Tunnel","Routing"],       desc:"Lab eksplorasi migrasi IPv4 ke IPv6 dengan dual-stack dan tunnel 6in4. Masih eksperimen — banyak yang belum dipahami." },
];
---

<Layout title="Projects — Ahmad Makhasin As Shufi">
  <Navbar active="projects" />

  <main>
    <div class="page-header">
      <div class="page-header-mesh" aria-hidden="true"></div>
      <div class="page-header-inner">
        <div class="overline" style="color:#a78bfa">Proyek & Lab</div>
        <h1 class="page-h1">
          Yang sudah<br />
          <em>dikerjakan.</em>
        </h1>
        <p class="page-sub">
          Bukan semuanya sempurna. Beberapa masih jalan,
          beberapa masih eksperimen. Tapi semuanya nyata.
        </p>
      </div>
    </div>

    <div class="section-divider" aria-hidden="true"></div>

    <section style="background:linear-gradient(180deg,#f0ecff 0%,#e8f4ff 100%);padding:80px 0 100px">
      <div class="section-wrap">
        <div class="projects-grid">
          {projects.map((p, i) => (
            <article class={`project-card card reveal d${(i % 3) + 1}`}>
              <div class="project-top">
                <span class="project-num">{p.num}</span>
                <span class={`project-status status-${p.status === "Selesai" ? "done" : p.status === "On-going" ? "ongoing" : "explore"}`}>
                  {p.status}
                </span>
              </div>
              <h3 class="project-title">{p.title}</h3>
              <p class="project-desc">{p.desc}</p>
              <div class="project-tags">
                {p.tags.map((t) => (
                  <span class="chip" style="font-size:10px;padding:4px 10px">{t}</span>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .page-header {
    background: linear-gradient(160deg, #2d1b69, #1a1035, #0f2744);
    padding: 140px 24px 72px;
    position: relative;
    overflow: hidden;
  }
  .page-header-mesh {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 60% at 80% 30%, rgba(139,92,246,0.28) 0%, transparent 60%),
      radial-gradient(ellipse 50% 70% at 10% 80%, rgba(34,211,238,0.14) 0%, transparent 55%);
    pointer-events: none;
  }
  .page-header-inner {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .page-header { padding: 160px 48px 80px; }
    .page-header-inner { padding: 0; }
  }

  .page-h1 {
    font-size: clamp(40px, 8vw, 72px);
    color: #f0eeff;
    margin-bottom: 14px;
  }
  .page-h1 em { font-style: normal; color: #22d3ee; }

  .page-sub {
    font-size: 14.5px;
    color: rgba(240,238,255,0.5);
    max-width: 360px;
    font-weight: 400;
    line-height: 1.75;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 560px) { .projects-grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 900px) { .projects-grid { grid-template-columns: 1fr 1fr 1fr; } }

  .project-card {
    padding: 24px 22px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .project-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .project-num {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: #a89cc0;
  }

  .project-status {
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 100px;
    border: 1px solid;
  }
  .status-done    { color: #059669; border-color: rgba(5,150,105,0.3);   background: rgba(5,150,105,0.08); }
  .status-ongoing { color: #d97706; border-color: rgba(217,119,6,0.3);   background: rgba(217,119,6,0.08); }
  .status-explore { color: #7c3aed; border-color: rgba(124,58,237,0.25); background: rgba(124,58,237,0.06); }

  .project-title {
    font-family: "Syne", sans-serif;
    font-size: 16px;
    font-weight: 700;
    color: #1a1035;
    letter-spacing: -0.02em;
    line-height: 1.25;
  }

  .project-desc {
    font-size: 13px;
    line-height: 1.75;
    color: #6b6080;
    flex: 1;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
</style>
