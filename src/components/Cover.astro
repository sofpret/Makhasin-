---
const photoSrc = "/images/anjai.jpg"; // ganti path foto kamu
const marqueeText = "NETWORK ENGINEER · CISCO · MIKROTIK · LINUX · TCP/IP · FIREWALL · VLAN · OSPF · INFRASTRUCTURE · MANAJEMEN PENDIDIKAN ·";
---

<section class="cover" id="cover">

  <!-- LAYER 1: Marquee di belakang foto -->
  <div class="marquee-layer" aria-hidden="true">
    <div class="mq-row mq-top">
      <div class="mq-track mq-fwd">
        <span>{marqueeText}</span><span>{marqueeText}</span><span>{marqueeText}</span>
      </div>
    </div>
    <div class="mq-row mq-mid">
      <div class="mq-track mq-rev">
        <span>{marqueeText}</span><span>{marqueeText}</span><span>{marqueeText}</span>
      </div>
    </div>
    <div class="mq-row mq-bot">
      <div class="mq-track mq-fwd" style="animation-duration:24s">
        <span>{marqueeText}</span><span>{marqueeText}</span><span>{marqueeText}</span>
      </div>
    </div>
  </div>

  <!-- LAYER 2: Foto full background -->
  <div class="photo-bg">
    {photoSrc ? (
      <img src={photoSrc} alt="Ahmad Makhasin As Shufi" class="photo-img" draggable="false" />
    ) : (
      <div class="photo-ph">
        <span class="ph-init">AM</span>
        <p class="ph-txt">Taruh foto kamu di /public/images/foto.jpg</p>
      </div>
    )}
    <div class="photo-overlay"></div>
  </div>


  <!-- LAYER 4: Role kanan (desktop only) -->
  <div class="cover-role" aria-hidden="true">
    <span>Network Engineer,</span>
    <span>Infrastructure &amp; Systems</span>
  </div>

  <!-- LAYER 5: Nama gede bawah -->
  <div class="name-block">
    <p class="name-eyebrow">Ahmad Makhasin As Shufi</p>
    <div class="name-line">
      <span class="nw nw-1" id="w1">AHMAD</span>
    </div>
    <div class="name-line">
      <span class="nw nw-2" id="w2">AS'SHUFI</span>
    </div>
  </div>

  <!-- Stats strip -->
  <div class="stats-strip">
    <div class="stat-item">
      <span class="stat-num">03<sup>+</sup></span>
      <span class="stat-lbl">Tahun belajar</span>
    </div>
    <div class="stat-sep" aria-hidden="true"></div>
    <div class="stat-item">
      <span class="stat-num">12<sup>+</sup></span>
      <span class="stat-lbl">Proyek selesai</span>
    </div>
    <div class="stat-sep" aria-hidden="true"></div>
    <div class="stat-item">
      <span class="stat-num">∞</span>
      <span class="stat-lbl">Curiosity</span>
    </div>
    <div class="stat-cta">
      <a href="/projects" class="cta-btn">
        Lihat Proyek
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a href="/public/cv.pdf" download class="cta-ghost">CV</a>
    </div>
  </div>

  <!-- Scroll hint -->
  <div class="scroll-hint" aria-hidden="true">
    <div class="sh-line"><div class="sh-fill"></div></div>
    <span class="sh-txt">scroll</span>
  </div>

</section>

<script>
  // Animasi masuk nama
  ["w1","w2"].forEach((id, i) => {
    const el = document.getElementById(id);
    if (!el) return;
    el.style.opacity = "0";
    el.style.transform = "translateY(48px)";
    el.style.transition = `opacity 1s cubic-bezier(0.16,1,0.3,1) ${0.15 + i*0.18}s, transform 1s cubic-bezier(0.16,1,0.3,1) ${0.15 + i*0.18}s`;
    requestAnimationFrame(() => requestAnimationFrame(() => {
      el.style.opacity = "1";
      el.style.transform = "translateY(0)";
    }));
  });

  // Parallax scroll ringan
  const photoImg  = document.querySelector(".photo-img")  as HTMLElement;
  const nameBlock = document.querySelector(".name-block") as HTMLElement;
  window.addEventListener("scroll", () => {
    const y = window.scrollY;
    if (photoImg)  photoImg.style.transform  = `translateY(${y * 0.22}px) scale(1.02)`;
    if (nameBlock) nameBlock.style.transform = `translateY(${y * 0.12}px)`;
  }, { passive: true });
</script>

<style>
  /* ── BASE ── */
  .cover {
    position: relative;
    width: 100%;
    height: 100dvh;
    min-height: 580px;
    overflow: hidden;
    background: #0c0a14;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  /* ── MARQUEE ── */
  .marquee-layer {
    position: absolute;
    inset: 0;
    z-index: 4; /* di atas foto dan overlay */
    display: flex;
    flex-direction: column;
    justify-content: space-around;
    padding: 5% 0;
    pointer-events: none;
    overflow: hidden;
  }

  .mq-row { width: 100%; overflow: hidden; }

  .mq-track {
    display: flex;
    white-space: nowrap;
    width: max-content;
  }

  .mq-track span {
    font-family: "Outfit", sans-serif;
    font-size: clamp(20px, 4vw, 50px);
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: transparent;
    -webkit-text-stroke: 1.5px rgba(255, 255, 255, 0.32);
    padding-right: 0.5em;
    user-select: none;
  }

  .mq-mid .mq-track span {
    -webkit-text-stroke: 1.5px rgba(167, 139, 250, 0.45);
  }

  .mq-fwd { animation: mqL 18s linear infinite; }
  .mq-rev { animation: mqR 21s linear infinite; }

  @keyframes mqL { from { transform: translateX(0); }         to { transform: translateX(-33.333%); } }
  @keyframes mqR { from { transform: translateX(-33.333%); } to { transform: translateX(0); } }

  /* ── FOTO ── */
  .photo-bg {
    position: absolute;
    inset: 0;
    z-index: 2;
  }

  .photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 12%; /* Mobile: wajah di atas */
    display: block;
    pointer-events: none;
    user-select: none;
    will-change: transform;
    transition: transform 0.08s linear;
  }

  @media (min-width: 768px) {
    .photo-img { object-position: center top; }
  }

  /* Placeholder */
  .photo-ph {
    width: 100%; height: 100%;
    background: linear-gradient(160deg, #1e1440, #0f2744);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 16px;
  }
  .ph-init {
    font-family: "Outfit", sans-serif;
    font-size: clamp(100px, 30vw, 220px);
    font-weight: 900;
    color: rgba(167,139,250,0.12);
    line-height: 1;
  }
  .ph-txt {
    font-size: 11px; font-weight: 500;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: rgba(167,139,250,0.28);
    text-align: center; padding: 0 24px;
  }

  /* Overlay gradients di atas foto */
  .photo-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to top,
        rgba(6, 4, 14, 0.97) 0%,
        rgba(6, 4, 14, 0.72) 30%,
        rgba(6, 4, 14, 0.2)  58%,
        transparent 76%
      ),
      linear-gradient(to bottom,
        rgba(6, 4, 14, 0.6) 0%,
        transparent 20%
      ),
      linear-gradient(to right,
        rgba(6, 4, 14, 0.4) 0%,
        transparent 55%
      );
    pointer-events: none;
  }

  /* ── NAVBAR ── */
  .cover-nav {
    position: absolute;
    top: 0; left: 0; right: 0;
    z-index: 10;
    padding: 18px 18px;
  }

  @media (min-width: 768px) {
    .cover-nav { padding: 24px 40px; }
  }

  .nav-left { display: flex; gap: 5px; flex-wrap: wrap; }

  .nav-pill {
    font-family: "Outfit", sans-serif;
    font-size: 11.5px; font-weight: 600;
    letter-spacing: 0.04em;
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    padding: 6px 14px;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 100px;
    backdrop-filter: blur(10px);
    background: rgba(255,255,255,0.04);
    transition: all 0.2s;
  }
  .nav-pill:hover { color:#fff; background:rgba(255,255,255,0.12); border-color:rgba(255,255,255,0.38); }
  .nav-pill.active { color:rgba(255,255,255,0.9); background:rgba(124,58,237,0.28); border-color:rgba(167,139,250,0.45); }

  /* ── ROLE KANAN (desktop) ── */
  .cover-role {
    display: none;
    position: absolute;
    right: 40px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 6;
    text-align: right;
    line-height: 1.6;
  }
  @media (min-width: 900px) { .cover-role { display: block; } }

  .cover-role span {
    display: block;
    font-family: "Outfit", sans-serif;
    font-size: 15px; font-weight: 500;
    color: rgba(255,255,255,0.68);
    letter-spacing: 0.02em;
  }

  /* ── NAMA GEDE ── */
  .name-block {
    position: relative;
    z-index: 6;
    padding: 0 16px 0;
    will-change: transform;
  }
  @media (min-width: 768px) { .name-block { padding: 0 40px 0; } }

  .name-eyebrow {
    font-family: "Outfit", sans-serif;
    font-size: 10.5px; font-weight: 600;
    letter-spacing: 0.24em; text-transform: uppercase;
    color: rgba(167,139,250,0.85);
    margin-bottom: 6px;
    display: flex; align-items: center; gap: 10px;
  }
  .name-eyebrow::before {
    content:''; display:inline-block;
    width:20px; height:1.5px; background:#a78bfa; flex-shrink:0;
  }

  .name-line {
    line-height: 0.88;
    overflow: hidden;
    display: block;
  }

  .nw {
    display: block;
    font-family: "Outfit", sans-serif;
    font-weight: 900;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: rgba(238,234,255,0.95);
    will-change: opacity, transform;
    line-height: 0.92;
  }

  /* Baris 1 lebih besar */
  .nw-1 { font-size: clamp(62px, 18.5vw, 168px); }

  /* Baris 2 sedikit lebih kecil + transparan sedikit — efek "di balik foto" */
  .nw-2 {
    font-size: clamp(46px, 14vw, 130px);
    color: rgba(238,234,255,0.82);
  }

  /* ── STATS STRIP ── */
  .stats-strip {
    position: relative;
    z-index: 6;
    display: flex;
    align-items: center;
    padding: 14px 16px 22px;
    border-top: 1px solid rgba(255,255,255,0.07);
    margin-top: 12px;
    flex-wrap: wrap;
    gap: 12px;
  }
  @media (min-width: 480px) {
    .stats-strip { flex-wrap:nowrap; gap:0; padding:16px 40px 28px; }
  }

  .stat-item {
    display: flex; flex-direction: column; gap: 2px;
    flex-shrink: 0;
  }
  @media (min-width: 480px) {
    .stat-item { padding: 0 20px; }
    .stat-item:first-child { padding-left: 0; }
  }

  .stat-num {
    font-family: "Outfit", sans-serif;
    font-size: clamp(20px, 4vw, 28px);
    font-weight: 900; color: #fff; line-height: 1;
  }
  .stat-num sup { font-size: 0.55em; color: #a78bfa; vertical-align: super; }

  .stat-lbl {
    font-size: 10px; font-weight: 500;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: rgba(255,255,255,0.28);
  }

  .stat-sep {
    width: 1px; height: 30px;
    background: rgba(255,255,255,0.09);
    flex-shrink: 0; display: none;
  }
  @media (min-width: 480px) { .stat-sep { display: block; } }

  .stat-cta {
    display: flex; gap: 8px;
    align-items: center;
    margin-left: auto;
  }

  .cta-btn {
    display: inline-flex; align-items: center; gap: 7px;
    font-family: "Outfit", sans-serif;
    font-size: 12px; font-weight: 700; letter-spacing: 0.04em;
    color: #0a0614;
    background: linear-gradient(135deg, #a78bfa, #22d3ee);
    border-radius: 100px; padding: 10px 20px;
    text-decoration: none; white-space: nowrap;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .cta-btn:hover { transform:translateY(-2px); box-shadow:0 8px 22px rgba(167,139,250,0.4); }

  .cta-ghost {
    display: inline-flex; align-items: center;
    font-family: "Outfit", sans-serif;
    font-size: 12px; font-weight: 600;
    color: rgba(255,255,255,0.48);
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.13);
    border-radius: 100px; padding: 10px 16px;
    text-decoration: none; white-space: nowrap;
    transition: all 0.2s;
  }
  .cta-ghost:hover { color:#fff; background:rgba(255,255,255,0.12); }

  /* ── SCROLL HINT ── */
  .scroll-hint {
    position: absolute; bottom:24px; right:16px;
    z-index: 10;
    display: flex; flex-direction:column; align-items:center; gap:6px;
  }
  @media (min-width:768px) { .scroll-hint { right:32px; } }

  .sh-line {
    width:1px; height:36px;
    background:rgba(255,255,255,0.09);
    overflow:hidden; position:relative;
  }
  .sh-fill {
    position:absolute; top:-36px; left:0;
    width:100%; height:36px;
    background:linear-gradient(to bottom,transparent,#a78bfa);
    animation:shA 2.2s ease-in-out infinite;
  }
  @keyframes shA { 0%{top:-36px;opacity:0} 20%{opacity:1} 100%{top:36px;opacity:0} }

  .sh-txt {
    font-size:8.5px; font-weight:600;
    letter-spacing:0.2em; text-transform:uppercase;
    color:rgba(255,255,255,0.18);
    writing-mode:vertical-rl;
  }
</style>