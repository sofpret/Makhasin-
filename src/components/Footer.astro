---
const year = new Date().getFullYear();

const socials = [
  { label: "GitHub",   href: "https://github.com/sofpret",
    icon: `<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>` },
  { label: "LinkedIn",  href: "https://linkedin.com/in/yourusername",
    icon: `<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>` },
  { label: "Email",    href: "mailto:hello@ahmadmakhasin.dev",
    icon: `<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>` },
];

const links = [
  { label: "Home",     href: "/" },
  { label: "About",    href: "/about" },
  { label: "Projects", href: "/projects" },
  { label: "Contact",  href: "/contact" },
];
---

<footer class="footer-wrap">
  <div class="footer-divider-gradient" aria-hidden="true"></div>

  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="/" class="footer-logo">AMS<span>_</span></a>
        <p class="footer-tagline">
          Jaringan bukan sekadar kabel dan paket.<br />
          Ini tentang bagaimana segala sesuatu terhubung.
        </p>
      </div>

      <nav class="footer-nav" aria-label="Navigasi footer">
        {links.map((l) => (
          <a href={l.href} class="footer-link">{l.label}</a>
        ))}
      </nav>

      <div class="footer-socials" aria-label="Media sosial">
        {socials.map((s) => (
          <a
            href={s.href}
            class="social-btn"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={s.label}
          >
            <Fragment set:html={s.icon} />
          </a>
        ))}
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-copy">© {year} Ahmad Makhasin As Shufi</p>
      <p class="footer-copy">SOFPRETTT</p>
    </div>
  </div>
</footer>

<style>
  .footer-wrap {
    background: #f0ecff;
    position: relative;
  }

  .footer-divider-gradient {
    height: 2px;
    background: linear-gradient(90deg, transparent, #a78bfa, #22d3ee, transparent);
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 48px 24px 32px;
  }

  @media (min-width: 768px) {
    .footer-inner { padding: 56px 48px 36px; }
  }

  .footer-top {
    display: flex;
    flex-direction: column;
    gap: 36px;
    margin-bottom: 36px;
  }

  @media (min-width: 768px) {
    .footer-top {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
    }
  }

  .footer-logo {
    font-family: "Syne", sans-serif;
    font-weight: 800;
    font-size: 18px;
    letter-spacing: 0.05em;
    color: #1a1035;
    text-decoration: none;
    display: block;
    margin-bottom: 12px;
    transition: color 0.2s;
  }
  .footer-logo span { color: #7c3aed; }
  .footer-logo:hover { color: #7c3aed; }

  .footer-tagline {
    font-size: 13.5px;
    line-height: 1.75;
    color: #6b6080;
    font-weight: 400;
    max-width: 220px;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-link {
    font-family: "Inter", sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #a89cc0;
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-link:hover { color: #7c3aed; }

  .footer-socials {
    display: flex;
    gap: 8px;
    align-items: flex-start;
    flex-wrap: wrap;
  }

  .social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: #fff;
    border: 1.5px solid rgba(124, 58, 237, 0.16);
    border-radius: 50%;
    color: #a89cc0;
    text-decoration: none;
    box-shadow: 0 2px 10px rgba(124, 58, 237, 0.07);
    transition: all 0.22s;
  }
  .social-btn:hover {
    background: #7c3aed;
    border-color: #7c3aed;
    color: #fff;
    transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(124, 58, 237, 0.3);
  }

  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: 4px;
    border-top: 1px solid rgba(124, 58, 237, 0.1);
    padding-top: 20px;
  }

  @media (min-width: 640px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .footer-copy {
    font-size: 12px;
    color: #a89cc0;
    font-weight: 400;
  }
</style>
