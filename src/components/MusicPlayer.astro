---
// Ganti URL ini dengan direct link .mp3 dari Pixabay atau sumber lain
const tracks = [
  {
    title: "Ambient Flow",
    artist: "Pixabay Music",
    url: "https://cdn.pixabay.com/audio/2024/03/12/audio_a567e4b4d5.mp3",
  },
  {
    title: "Digital Dreams",
    artist: "Pixabay Music",
    url: "https://cdn.pixabay.com/audio/2023/10/30/audio_9f563aaed6.mp3",
  },
];
---

<!-- Floating music player -->
<div class="music-player" id="musicPlayer" aria-label="Music Player">
  <!-- Tab penarik (selalu keliatan) -->
  <button class="music-tab" id="musicTab" aria-label="Toggle music player" title="Music Player">
    <span class="music-tab-icon" id="tabIcon">
      <!-- Note icon -->
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 18V5l12-2v13"/>
        <circle cx="6" cy="18" r="3"/>
        <circle cx="18" cy="16" r="3"/>
      </svg>
    </span>
    <span class="music-tab-label">Music</span>
    <span class="music-eq" id="musicEq" aria-hidden="true">
      <span></span><span></span><span></span><span></span>
    </span>
  </button>

  <!-- Panel player -->
  <div class="music-panel" id="musicPanel">
    <!-- Track info -->
    <div class="track-info">
      <div class="track-disc" id="trackDisc">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/>
          <circle cx="12" cy="12" r="3"/>
        </svg>
      </div>
      <div class="track-meta">
        <div class="track-title" id="trackTitle">Ambient Flow</div>
        <div class="track-artist" id="trackArtist">Pixabay Music</div>
      </div>
    </div>

    <!-- Progress -->
    <div class="progress-wrap">
      <div class="progress-bar-bg" id="progressBg">
        <div class="progress-bar-fill" id="progressFill"></div>
      </div>
      <div class="progress-times">
        <span id="currentTime">0:00</span>
        <span id="totalTime">0:00</span>
      </div>
    </div>

    <!-- Controls -->
    <div class="controls">
      <button class="ctrl-btn" id="prevBtn" aria-label="Previous track" title="Previous">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="19 20 9 12 19 4 19 20"/><line x1="5" y1="19" x2="5" y2="5"/></svg>
      </button>

      <button class="ctrl-btn play-btn" id="playBtn" aria-label="Play/Pause">
        <svg class="icon-play" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        <svg class="icon-pause" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="display:none"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
      </button>

      <button class="ctrl-btn" id="nextBtn" aria-label="Next track" title="Next">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 4 15 12 5 20 5 4"/><line x1="19" y1="5" x2="19" y2="19"/></svg>
      </button>
    </div>

    <!-- Volume -->
    <div class="volume-row">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
      <input type="range" class="volume-slider" id="volumeSlider" min="0" max="100" value="70" aria-label="Volume" />
    </div>
  </div>
</div>

<script define:vars={{ tracks }}>
  const audio    = new Audio();
  audio.crossOrigin = "anonymous";
  let currentTrack = 0;
  let isPlaying    = false;

  const player     = document.getElementById("musicPlayer");
  const tab        = document.getElementById("musicTab");
  const panel      = document.getElementById("musicPanel");
  const playBtn    = document.getElementById("playBtn");
  const prevBtn    = document.getElementById("prevBtn");
  const nextBtn    = document.getElementById("nextBtn");
  const trackTitle  = document.getElementById("trackTitle");
  const trackArtist = document.getElementById("trackArtist");
  const progressFill= document.getElementById("progressFill");
  const progressBg  = document.getElementById("progressBg");
  const currentTime = document.getElementById("currentTime");
  const totalTime   = document.getElementById("totalTime");
  const volumeSlider= document.getElementById("volumeSlider");
  const trackDisc   = document.getElementById("trackDisc");
  const musicEq     = document.getElementById("musicEq");

  function formatTime(s) {
    const m = Math.floor(s / 60);
    return `${m}:${String(Math.floor(s % 60)).padStart(2,"0")}`;
  }

  function loadTrack(idx) {
    const t = tracks[idx];
    audio.src = t.url;
    audio.volume = (volumeSlider?.value || 70) / 100;
    if (trackTitle)  trackTitle.textContent  = t.title;
    if (trackArtist) trackArtist.textContent = t.artist;
    if (progressFill) progressFill.style.width = "0%";
    if (currentTime) currentTime.textContent = "0:00";
  }

  function play() {
    audio.play().catch(() => {});
    isPlaying = true;
    document.querySelector(".icon-play")?.setAttribute("style","display:none");
    document.querySelector(".icon-pause")?.setAttribute("style","display:block");
    if (trackDisc) trackDisc.classList.add("spinning");
    if (musicEq)   musicEq.classList.add("playing");
  }

  function pause() {
    audio.pause();
    isPlaying = false;
    document.querySelector(".icon-play")?.setAttribute("style","display:block");
    document.querySelector(".icon-pause")?.setAttribute("style","display:none");
    if (trackDisc) trackDisc.classList.remove("spinning");
    if (musicEq)   musicEq.classList.remove("playing");
  }

  playBtn?.addEventListener("click", () => isPlaying ? pause() : play());

  prevBtn?.addEventListener("click", () => {
    currentTrack = (currentTrack - 1 + tracks.length) % tracks.length;
    loadTrack(currentTrack);
    if (isPlaying) play();
  });

  nextBtn?.addEventListener("click", () => {
    currentTrack = (currentTrack + 1) % tracks.length;
    loadTrack(currentTrack);
    if (isPlaying) play();
  });

  audio.addEventListener("timeupdate", () => {
    if (!audio.duration) return;
    const pct = (audio.currentTime / audio.duration) * 100;
    if (progressFill) progressFill.style.width = pct + "%";
    if (currentTime) currentTime.textContent = formatTime(audio.currentTime);
  });

  audio.addEventListener("loadedmetadata", () => {
    if (totalTime) totalTime.textContent = formatTime(audio.duration);
  });

  audio.addEventListener("ended", () => {
    currentTrack = (currentTrack + 1) % tracks.length;
    loadTrack(currentTrack);
    play();
  });

  // Seek on click
  progressBg?.addEventListener("click", (e) => {
    const r   = progressBg.getBoundingClientRect();
    const pct = (e.clientX - r.left) / r.width;
    audio.currentTime = pct * audio.duration;
  });

  volumeSlider?.addEventListener("input", () => {
    audio.volume = Number(volumeSlider.value) / 100;
  });

  // Toggle panel
  let isOpen = false;
  tab?.addEventListener("click", () => {
    isOpen = !isOpen;
    player?.classList.toggle("is-open", isOpen);
  });

  // Load first track
  loadTrack(0);
</script>

<style>
  .music-player {
    position: fixed;
    bottom: 24px;
    right: 0;
    z-index: 60;
    display: flex;
    align-items: flex-end;
    gap: 0;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  /* Panel hidden by default (translated right) */
  .music-panel {
    width: 240px;
    background: var(--bg-card);
    border: 1.5px solid var(--border);
    border-right: none;
    border-radius: 16px 0 0 16px;
    padding: 16px;
    box-shadow: -8px 8px 32px rgba(124,58,237,0.18);
    transform: translateX(100%);
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    pointer-events: none;
    opacity: 0;
  }

  .music-player.is-open .music-panel {
    transform: translateX(0);
    pointer-events: all;
    opacity: 1;
  }

  /* Tab */
  .music-tab {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    width: 44px;
    padding: 12px 0;
    background: linear-gradient(160deg, #7c3aed, #22d3ee);
    border: none;
    border-radius: 12px 0 0 12px;
    cursor: pointer;
    color: #fff;
    box-shadow: -4px 4px 16px rgba(124,58,237,0.3);
    transition: width 0.2s;
    flex-shrink: 0;
  }
  .music-tab:hover { width: 48px; }

  .music-tab-icon { display: flex; align-items: center; justify-content: center; }
  .music-tab-label {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.75);
    writing-mode: vertical-rl;
    text-orientation: mixed;
    transform: rotate(180deg);
  }

  /* EQ bars */
  .music-eq {
    display: flex;
    gap: 2px;
    align-items: flex-end;
    height: 14px;
  }
  .music-eq span {
    display: block;
    width: 3px;
    background: rgba(255,255,255,0.6);
    border-radius: 2px;
    height: 4px;
    transition: height 0.1s;
  }
  .music-eq.playing span:nth-child(1) { animation: eq1 0.5s ease-in-out infinite; }
  .music-eq.playing span:nth-child(2) { animation: eq2 0.4s ease-in-out infinite 0.1s; }
  .music-eq.playing span:nth-child(3) { animation: eq3 0.6s ease-in-out infinite 0.05s; }
  .music-eq.playing span:nth-child(4) { animation: eq4 0.45s ease-in-out infinite 0.15s; }

  @keyframes eq1 { 0%,100%{height:3px} 50%{height:12px} }
  @keyframes eq2 { 0%,100%{height:8px} 50%{height:4px} }
  @keyframes eq3 { 0%,100%{height:5px} 50%{height:13px} }
  @keyframes eq4 { 0%,100%{height:10px} 50%{height:3px} }

  /* Track info */
  .track-info {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }

  .track-disc {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--violet), #22d3ee);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    flex-shrink: 0;
    transition: transform 0.3s;
  }
  .track-disc.spinning { animation: discSpin 3s linear infinite; }
  @keyframes discSpin { to { transform: rotate(360deg); } }

  .track-title {
    font-size: 13px;
    font-weight: 700;
    color: var(--text-1);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .track-artist {
    font-size: 11px;
    font-weight: 400;
    color: var(--text-4);
    margin-top: 2px;
  }

  /* Progress */
  .progress-wrap { margin-bottom: 12px; }

  .progress-bar-bg {
    height: 4px;
    background: var(--border);
    border-radius: 100px;
    cursor: pointer;
    margin-bottom: 5px;
    overflow: hidden;
    position: relative;
  }

  .progress-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--violet), #22d3ee);
    border-radius: 100px;
    width: 0%;
    transition: width 0.5s linear;
    pointer-events: none;
  }

  .progress-times {
    display: flex;
    justify-content: space-between;
    font-size: 10px;
    color: var(--text-4);
    font-weight: 500;
  }

  /* Controls */
  .controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-bottom: 12px;
  }

  .ctrl-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: none;
    background: var(--border);
    color: var(--text-2);
    cursor: pointer;
    transition: all 0.2s;
  }
  .ctrl-btn:hover { background: var(--violet); color: #fff; transform: scale(1.08); }

  .play-btn {
    width: 42px;
    height: 42px;
    background: linear-gradient(135deg, var(--violet), #22d3ee);
    color: #fff;
    box-shadow: 0 4px 14px rgba(124,58,237,0.35);
  }
  .play-btn:hover { transform: scale(1.1); background: linear-gradient(135deg,#9f67ff,#38e8ff); }

  /* Volume */
  .volume-row {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--text-4);
  }

  .volume-slider {
    flex: 1;
    height: 3px;
    -webkit-appearance: none;
    appearance: none;
    background: var(--border);
    border-radius: 100px;
    outline: none;
    cursor: pointer;
  }
  .volume-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--violet);
    cursor: pointer;
    box-shadow: 0 0 4px rgba(124,58,237,0.5);
  }
</style>