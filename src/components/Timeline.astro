---
const items = [
  { year:"2022", side:"left",  color:"violet", title:"Mulai kuliah",               desc:"Masuk jurusan Manajemen Pendidikan. Sadar bahwa administrasi dan sistem punya bahasa yang sama." },
  { year:"2022", side:"right", color:"cyan",   title:"Kenal networking",            desc:"Belajar mandiri dari dokumentasi Cisco dan forum. Setup lab virtual pertama pakai GNS3 — langsung ketagihan." },
  { year:"2023", side:"left",  color:"violet", title:"Lab pertama berhasil",        desc:"Konfigurasi VLAN, inter-VLAN routing, dan NAT di lab simulasi. Dari sini susah balik lagi." },
  { year:"2023", side:"right", color:"cyan",   title:"Masuk dunia Linux",           desc:"Ubuntu, Debian, bash scripting. Mulai ngerti kenapa sysadmin selalu senyum di depan terminal." },
  { year:"2024", side:"left",  color:"violet", title:"Proyek jaringan pertama",     desc:"Implementasi infrastruktur jaringan kecil. Hasilnya berjalan. Tidak ada yang lebih memuaskan." },
  { year:"2025", side:"right", color:"cyan",   title:"Terus berkembang",            desc:"Security, monitoring, automation — banyak yang belum disentuh, banyak yang ingin dijelajahi." },
];

const skills = [
  { label:"Cisco IOS", c:"violet" }, { label:"MikroTik",  c:"violet" },
  { label:"Linux",     c:"cyan"   }, { label:"TCP/IP",    c:"cyan"   },
  { label:"GNS3",      c:"violet" }, { label:"Firewall",  c:"cyan"   },
  { label:"VLAN",      c:"violet" }, { label:"OSPF",      c:"cyan"   },
  { label:"Bash",      c:"violet" }, { label:"pfSense",   c:"cyan"   },
];
---

<div class="section-divider" aria-hidden="true"></div>

<section class="tl-section">
  <div class="tl-inner">

    <div class="tl-head reveal">
      <div class="section-tag">Perjalanan</div>
      <h2 class="tl-title">
        Bagaimana sampai<br />
        <em>di sini.</em>
      </h2>
      <p class="typewriter tl-sub" data-text="Bukan jalur yang lurus. Tapi setiap titiknya disengaja." data-speed="40"></p>
    </div>

    <div class="tl-track" role="list">
      <div class="tl-center-line" aria-hidden="true"></div>

      {items.map((item, i) => (
        <div
          class={`tl-item tl-${item.side} reveal d${(i % 4) + 1} ${i === 0 ? "tl-item--active" : ""}`}
          role="listitem"
          data-index={i}
          tabindex="0"
        >
          {item.side === "left" ? (
            <>
              <div class="tl-card-wrap tl-left">
                <div class={`tl-card tl-card--${item.color}`}>
                  <div class={`tl-year tl-year--${item.color}`}>{item.year}</div>
                  <h3 class="tl-card-title typewriter" data-text={item.title} data-speed="42"></h3>
                  <p class="tl-card-desc">{item.desc}</p>
                </div>
              </div>
              <div class="tl-dot-col">
                <div class={`tl-dot tl-dot--${item.color}`} aria-hidden="true"></div>
              </div>
              <div class="tl-spacer"></div>
            </>
          ) : (
            <>
              <div class="tl-spacer"></div>
              <div class="tl-dot-col">
                <div class={`tl-dot tl-dot--${item.color}`} aria-hidden="true"></div>
              </div>
              <div class="tl-card-wrap tl-right">
                <div class={`tl-card tl-card--${item.color}`}>
                  <div class={`tl-year tl-year--${item.color}`}>{item.year}</div>
                  <h3 class="tl-card-title typewriter" data-text={item.title} data-speed="42"></h3>
                  <p class="tl-card-desc">{item.desc}</p>
                </div>
              </div>
            </>
          )}
        </div>
      ))}
    </div>

    <!-- Skills -->
    <div class="skills-wrap reveal d2">
      <div class="skills-label">Tech Stack</div>
      <div class="skills-chips">
        {skills.map((s) => (
          <span class={`chip ${s.c === "cyan" ? "chip-cyan" : ""}`}>{s.label}</span>
        ))}
      </div>
    </div>

  </div>
</section>

<script>
  document.querySelectorAll(".tl-item").forEach((item) => {
    const activate = () => {
      document.querySelectorAll(".tl-item").forEach((i) => i.classList.remove("tl-item--active"));
      item.classList.add("tl-item--active");
    };
    item.addEventListener("click", activate);
    item.addEventListener("keydown", (e) => {
      if ((e as KeyboardEvent).key === "Enter") { e.preventDefault(); activate(); }
    });
  });
</script>

<style>
  .tl-section {
    background: linear-gradient(180deg, var(--bg) 0%, var(--bg-2) 100%);
    padding: 72px 0 80px;
    position: relative;
    transition: background 0.3s;
  }

  .tl-inner {
    max-width: 820px;
    margin: 0 auto;
    padding: 0 20px;
    position: relative;
    z-index: 1;
  }
  @media (min-width: 768px) { .tl-inner { padding: 0 48px; } }

  .tl-head { text-align: center; margin-bottom: 52px; }

  .tl-title {
    font-size: clamp(30px, 6vw, 48px);
    color: var(--text-1);
    margin-bottom: 12px;
  }
  .tl-title em { font-style: normal; color: var(--violet); }

  .tl-sub {
    font-size: 14.5px;
    color: var(--text-3);
    max-width: 320px;
    margin: 0 auto;
    min-height: 1.4em;
  }

  .tl-track {
    position: relative;
    display: flex;
    flex-direction: column;
    margin-bottom: 60px;
  }

  .tl-center-line {
    position: absolute;
    left: 50%;
    top: 0; bottom: 0;
    width: 1.5px;
    background: linear-gradient(to bottom, transparent 0%, var(--violet-light) 8%, var(--violet-light) 92%, transparent 100%);
    transform: translateX(-50%);
    pointer-events: none;
  }

  @media (max-width: 539px) {
    .tl-center-line { left: 14px; }
  }

  .tl-item {
    display: grid;
    grid-template-columns: 1fr 20px 1fr;
    gap: 0 14px;
    padding-bottom: 32px;
    cursor: pointer;
    outline: none;
  }

  @media (max-width: 539px) {
    .tl-item { grid-template-columns: 28px 1fr; gap: 0 12px; }
    .tl-spacer { display: none; }
    .tl-card-wrap { grid-column: 2; }
    .tl-dot-col { grid-column: 1; grid-row: 1; }
  }

  .tl-card-wrap { display: flex; align-items: flex-start; }
  .tl-left  { justify-content: flex-end; }
  .tl-right { justify-content: flex-start; }

  .tl-card {
    background: var(--bg-card);
    border-radius: 14px;
    padding: 16px 18px;
    border: 1.5px solid var(--border);
    box-shadow: var(--shadow-sm);
    max-width: 270px;
    width: 100%;
    transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1),
                box-shadow 0.3s, border-color 0.3s, opacity 0.3s;
    transform: translateY(5px);
    opacity: 0.6;
  }
  @media (max-width: 539px) { .tl-card { max-width: 100%; } }

  .tl-item--active .tl-card,
  .tl-item:hover .tl-card {
    transform: translateY(0) scale(1.02);
    opacity: 1;
    box-shadow: var(--shadow-lg);
    border-color: var(--border-hover);
  }

  .tl-year {
    font-size: 10px; font-weight: 700;
    letter-spacing: 0.18em; text-transform: uppercase;
    margin-bottom: 6px;
  }
  .tl-year--violet { color: var(--violet); }
  .tl-year--cyan   { color: var(--cyan); }

  .tl-card-title {
    font-family: "Outfit", sans-serif;
    font-size: 15px; font-weight: 700;
    color: var(--text-1);
    letter-spacing: -0.01em;
    line-height: 1.25;
    margin-bottom: 7px;
    min-height: 1.25em;
  }

  .tl-card-desc {
    font-size: 13px; line-height: 1.7;
    color: var(--text-3); font-weight: 400;
  }

  .tl-dot-col {
    display: flex; justify-content: center;
    align-items: flex-start; padding-top: 18px;
    position: relative; z-index: 1;
  }

  .tl-dot {
    width: 13px; height: 13px; border-radius: 50%;
    background: var(--bg-card);
    border: 2px solid var(--violet-light);
    transition: all 0.3s cubic-bezier(0.34,1.56,0.64,1);
    flex-shrink: 0;
  }
  .tl-dot--cyan { border-color: var(--cyan-bright); }

  .tl-item--active .tl-dot--violet,
  .tl-item:hover  .tl-dot--violet {
    background: var(--violet); border-color: var(--violet);
    box-shadow: 0 0 0 5px rgba(124,58,237,0.18);
    transform: scale(1.3);
  }
  .tl-item--active .tl-dot--cyan,
  .tl-item:hover  .tl-dot--cyan {
    background: var(--cyan-bright); border-color: var(--cyan-bright);
    box-shadow: 0 0 0 5px rgba(34,211,238,0.18);
    transform: scale(1.3);
  }

  /* Skills */
  .skills-wrap { text-align: center; }
  .skills-label {
    font-size: 10px; font-weight: 700;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--violet-light); margin-bottom: 14px;
  }
  .skills-chips {
    display: flex; flex-wrap: wrap;
    gap: 8px; justify-content: center;
  }
</style>